# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# Supabase database password (Project Settings -> Database -> Reset / show password)
DB_PASSWORD=YOUR_SUPABASE_PASSWORD_HERE

# Optional overrides for the pooled Supabase connection used by the DB-backed services.
# Set these if your project uses a different pooler URL or DB role than the defaults in the service configs.
DB_URL=jdbc:postgresql://aws-1-ap-south-1.pooler.supabase.com:5432/postgres?currentSchema=users
DB_USERNAME=postgres.your_project_ref

# Optional JWT override
#JWT_SECRET=ThisIsASecretKeyForSmartLabEquipmentBookingSystemMustBeAtLeast32Bytes

# ===== Main Admin (seeded on first boot if missing) =====
#ADMIN_EMAIL=admin@foe.sjp.ac.lk
#ADMIN_PASSWORD=Admin123

# ===== Department Admins (one per department; leave blank to skip) =====
# Department Admin manages labs, instructors, HoDs, lecturers within their department.
DEPT_ADMIN_COMPUTER_EMAIL=
DEPT_ADMIN_COMPUTER_PASSWORD=
DEPT_ADMIN_ELECTRICAL_EMAIL=
DEPT_ADMIN_ELECTRICAL_PASSWORD=
DEPT_ADMIN_MECHANICAL_EMAIL=
DEPT_ADMIN_MECHANICAL_PASSWORD=
DEPT_ADMIN_CIVIL_EMAIL=
DEPT_ADMIN_CIVIL_PASSWORD=
